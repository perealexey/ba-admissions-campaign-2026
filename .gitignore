# Сырые данные абитуриентов (idEpgu, баллы, статусы — не ФИО, но не
# агрегировано) и технические артефакты сбора — регенерируются
# collector_bak.py локально, не для публичного репозитория.
bak_data/
har/
cowork_output/
pk.hse.ru*.html

# Посчитанные метрики (data/*.csv, *.parquet) — производные от bak_data/,
# та же логика: не в репозитории. Дашборд на Streamlit Cloud, когда дойдёт
# до деплоя, будет читать их из приватного хранилища (Google Drive), не из
# репозитория — см. summer_campaign_26/docs/PIPELINE.md §7 для образца.
data/

# КЦП-источники (RTF/HTML) — публичные документы ВШЭ, но большие и не
# нужны дашборду напрямую (нужны только parse_supply_bak.py при пересчёте);
# держим локально, не в репозитории.
docs/*.rtf
docs/*.html

# Локальные dev-инструменты (Claude Code preview), не часть проекта
.claude/

# Секреты (пароль дашборда, ключ сервисного аккаунта Google — когда появятся)
.streamlit/secrets.toml
.streamlit/*.json

# Системное
.DS_Store
__pycache__/
*.pyc
